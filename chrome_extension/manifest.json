{
  "manifest_version": 3,
  "name": "护肤品价格采集助手",
  "version": "2.0.0",
  "description": "半自动采集淘宝、天猫、抖音商品页可见价格并提交到本地服务。",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "https://*.taobao.com/*",
    "https://*.tmall.com/*",
    "https://*.tmall.hk/*",
    "https://*.douyin.com/*",
    "https://*.jinritemai.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "护肤品价格采集助手"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.taobao.com/*",
        "https://*.tmall.com/*",
        "https://*.tmall.hk/*",
        "https://*.douyin.com/*",
        "https://*.jinritemai.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
